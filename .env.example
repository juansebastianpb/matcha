# --- Client (bundled into the browser — safe to expose) ---
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_CHALLENGE_GAME_ID=your-challenge-game-id
# Optional: override Challenge widget URLs (defaults to production CDN)
# VITE_CHALLENGE_WIDGET_URL=http://localhost:4837/widget/dist/challenge-widget.js
# VITE_CHALLENGE_BUTTON_URL=http://localhost:4837/widget/dist/challenge-button.js

# --- Server-only (Vercel env vars — NEVER VITE_-prefixed, never in client JS) ---
# Used by api/challenge/settle.ts.
# CHALLENGE_API_KEY is the Challenge sk_live_ key. Do NOT add VITE_CHALLENGE_API_KEY.
CHALLENGE_API_KEY=your-challenge-sk-live-key
# Supabase service role key — backs the consensus settlement table.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional: override Challenge API base (defaults to https://api.withchallenge.com)
# CHALLENGE_API_BASE=http://localhost:4837
